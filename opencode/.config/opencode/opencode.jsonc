{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {},
  "formatter": {},
  "permission": {
    "bash": "ask",
    "edit": "ask",
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "lsp": "allow",
    "skill": "allow",
    "todowrite": "allow",
    "webfetch": "ask",
    "websearch": "ask",
    "question": "allow",
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp/oauth",
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
    },
    "deep-wiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp",
    },
    "aws-knowledge": {
      "type": "remote",
      "url": "https://knowledge-mcp.global.api.aws",
    },
    "sem": {
      "type": "local",
      "command": ["sem", "mcp"],
    },
    "kubernetes": {
      "type": "local",
      "command": ["kubernetes-mcp-server", "--read-only"],
    },
  },
}
